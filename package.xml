<?xml version="1.0"?>
<package format="3">
    <name>hex_ros_urdf_archer_y6</name>
    <version>0.1.0</version>
    <description>The hex_ros_urdf_archer_y6 package</description>
    <maintainer email="dzr159@gmail.com">Dong Zhaorui</maintainer>
    <license>Apache 2.0</license>

    <buildtool_depend condition="$ROS_VERSION == 1">catkin</buildtool_depend>
    <depend condition="$ROS_VERSION == 1">roslaunch</depend>
    <depend condition="$ROS_VERSION == 1">joint_state_publisher</depend>
    <depend condition="$ROS_VERSION == 1">joint_state_publisher_gui</depend>
    <depend condition="$ROS_VERSION == 1">robot_state_publisher</depend>
    <depend condition="$ROS_VERSION == 1">rviz</depend>
    <depend condition="$ROS_VERSION == 1">gazebo</depend>


    <buildtool_depend condition="$ROS_VERSION == 2">ament_cmake</buildtool_depend>
    <exec_depend condition="$ROS_VERSION == 2">joint_state_publisher</exec_depend>
    <exec_depend condition="$ROS_VERSION == 2">joint_state_publisher_gui</exec_depend>
    <exec_depend condition="$ROS_VERSION == 2">robot_state_publisher</exec_depend>
    <exec_depend condition="$ROS_VERSION == 2">rviz2</exec_depend>
    <exec_depend condition="$ROS_VERSION == 2">xacro</exec_depend>

    
    <export>
        <build_type condition="$ROS_VERSION == 2">ament_cmake</build_type>
    </export>
</package>
